# Exclusion patterns for check_internal_links.py
# Each line is a regex matched against "source_file:link_url"

# Contributing-docs pages referencing repo-level files
# DEVELOPER.md and SHORTCODES.md are repo files, not Hugo content pages
contributing-docs/shortcodes\.md:DEVELOPER\.md
contributing-docs/authoring\.md:SHORTCODES\.md

# API reference auto-generated cross-references (case mismatch in generated content)
# api-reference/flyte-sdk/
# api-reference/plugins/

# Links inside variant-conditional blocks (checker doesn't process Hugo shortcodes)
# These links are only rendered for their target variant
community/_index\.md:\./joining-the-community
community/_index\.md:\./contributing-code

# Links inside HTML comments (TODO placeholders for planned pages)
user-guide/task-configuration/_index\.md

# Link inside variant-conditional block (byoc block on selfmanaged-only page)
deployment/architecture/overview\.md:\.\./configuring-your-data-plane

integrations/_index\.md:\./openai

# page.md links on flyte-context page (build artifact, not a Hugo page)
flyte-context\.md:page\.md

# section.md bundle links (build artifacts generated by make llm-docs, not Hugo pages)
section\.md

# Auto-generated CLI docs with cross-variant and stale links
api-reference/flytectl-cli/
api-reference/pyflyte-cli\.md
api-reference/union-cli\.md

# Links inside variant-conditional blocks on deployment index — flyte subdir
# links are inside a {{< variant flyte >}} block, so they only render in flyte
# even though the page itself is +flyte +union
deployment/_index\.md:\./flyte-deployment/_index
deployment/_index\.md:\./flyte-configuration/_index
deployment/_index\.md:\./flyte-connectors/_index
deployment/_index\.md:\./flyte-plugins/_index
deployment/_index\.md:\./configuration-reference/_index
